#!/bin/zsh
# Stop script for Amelia Island Coastline Evolution
# Kills HTTP server on port 8765.

PORT=8765

echo "Stopping Amelia Island Coastline Evolution..."
echo ""

if lsof -i :${PORT} > /dev/null 2>&1; then
    PID=$(lsof -ti :${PORT})
    echo "   Stopping process (PID: ${PID})..."
    kill -9 ${PID} 2>/dev/null
    sleep 1

    if lsof -i :${PORT} > /dev/null 2>&1; then
        echo "   Failed to stop process"
        exit 1
    else
        echo "   Server stopped"
    fi
else
    echo "   No server running on port ${PORT}"
fi
